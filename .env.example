GEMINI_API_KEY=your_gemini_key_here
GITHUB_TOKEN=your_github_token_here

# Optional — a second Gemini key used only for embeddings (search + ingestion),
# separate from GEMINI_API_KEY's generation/extraction calls. Splits the free tier's
# 5 requests/minute limit into two independent pools instead of one shared one.
# Falls back to GEMINI_API_KEY if unset.
GEMINI_EMBEDDING_API_KEY=your_second_gemini_key_here

# Optional — comma-separated pool of keys for commit/PR extraction during ingest.
# Each key has its own independent 5-req/min AND 20-req/day free-tier quota, so N keys
# means N times the extraction throughput. Falls back to just GEMINI_API_KEY if unset.
GEMINI_EXTRACTION_API_KEYS=key_one_here,key_two_here,key_three_here

# Any public GitHub repo — 'owner/repo' or a full GitHub URL
# Used by the ingestion test script and (eventually) as the default target
TEST_REPO=vercel/ms
